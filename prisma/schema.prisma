// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/shared/modules/generated/prisma"
}

generator openapi {
  provider    = "prisma-openapi"
  title       = "Specialized Messenger"
  description = "Prisma entities docs"
  output      = "../src/shared/modules/generated/prisma-docs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  publicId  String   @unique @db.Uuid
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  login     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      UserRole @default(USER)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  sentInvitations Invitation[]
  participants    ConversationParticipant[]
  messages        Message[]
}

enum InvitationStatus {
  PENDING
  ACCEPTED
}

model Invitation {
  id           BigInt           @id @default(autoincrement()) @db.BigInt
  publicId     String           @unique @db.Uuid
  firstName    String           @db.VarChar(100)
  lastName     String           @db.VarChar(100)
  authorUserId BigInt           @db.BigInt
  status       InvitationStatus @default(PENDING)
  createdAt    DateTime         @default(now()) @db.Timestamptz

  author User @relation(fields: [authorUserId], references: [id])
}

enum ConversationType {
  DIRECT
  GROUP
}

model Conversation {
  id        BigInt           @id @default(autoincrement()) @db.BigInt
  publicId  String           @unique @db.Uuid
  name      String?          @db.VarChar(100)
  type      ConversationType
  createdAt DateTime         @default(now()) @db.Timestamptz
  updatedAt DateTime         @updatedAt @db.Timestamptz

  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt(sort: Desc)])
}

enum ParticipantRole {
  OWNER
  MEMBER
}

model ConversationParticipant {
  id             BigInt          @id @default(autoincrement())
  conversationId BigInt          @db.BigInt
  userId         BigInt          @db.BigInt
  role           ParticipantRole @default(MEMBER)
  joinedAt       DateTime        @default(now()) @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
}

enum MessageType {
  SYSTEM_CONVERSATION_CREATED
  SYSTEM_USER_JOINED
  TEXT
}

model Message {
  id             BigInt      @id @default(autoincrement()) @db.BigInt
  publicId       String      @unique @db.Uuid
  conversationId BigInt      @db.BigInt
  authorUserId   BigInt?     @db.BigInt
  type           MessageType
  content        String      @db.VarChar(1000)
  createdAt      DateTime    @default(now()) @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User?        @relation(fields: [authorUserId], references: [id])

  @@index([conversationId, createdAt(sort: Desc)])
}

